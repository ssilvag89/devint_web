---
// Call to Action Section
---

<section class="py-20 relative overflow-hidden">
  <!-- Background gradient -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-emerald-600/10 via-cyan-600/10 to-emerald-600/10"
  >
  </div>

  <!-- Pattern overlay -->
  <div class="absolute inset-0 opacity-10">
    <svg
      class="w-full h-full"
      viewBox="0 0 100 100"
      xmlns="http://www.w3.org/2000/svg"
    >
      <pattern
        id="cta-pattern"
        x="0"
        y="0"
        width="20"
        height="20"
        patternUnits="userSpaceOnUse"
      >
        <circle
          cx="10"
          cy="10"
          r="1"
          fill="currentColor"
          class="text-emerald-400"></circle>
      </pattern>
      <rect width="100%" height="100%" fill="url(#cta-pattern)"></rect>
    </svg>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div
      class="bg-gradient-to-br from-slate-800/80 to-slate-900/80 backdrop-blur-sm rounded-3xl border border-slate-700/50 p-12 md:p-16 shadow-2xl"
    >
      <div class="max-w-4xl mx-auto text-center">
        <!-- Badge -->
        <div
          class="inline-flex items-center space-x-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-4 py-2 mb-6"
        >
          <svg
            class="w-5 h-5 text-emerald-400"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              fill-rule="evenodd"
              d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
              clip-rule="evenodd"></path>
          </svg>
          <span class="text-sm font-semibold text-emerald-400"
            >Transformamos tu negocio</span
          >
        </div>

        <!-- Heading -->
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
          ¿Listo para
          <span
            class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent"
          >
            Digitalizar
          </span>
          tu Empresa?
        </h2>

        <p
          class="text-xl text-slate-300 leading-relaxed mb-10 max-w-2xl mx-auto"
        >
          Cotiza tu proyecto sin compromiso. Te respondemos en menos de 24 horas
          con una propuesta personalizada y presupuesto transparente.
        </p>

        <!-- CTA Buttons -->
        <div
          class="flex flex-col sm:flex-row gap-4 justify-center items-center"
        >
          <a
            href="/contacto"
            data-cta="true"
            class="bg-gradient-to-r from-emerald-500 to-cyan-500 text-white px-10 py-4 rounded-full font-semibold hover:from-emerald-600 hover:to-cyan-600 transition-all duration-300 shadow-lg hover:shadow-emerald-500/25 group flex items-center justify-center space-x-2"
          >
            <span>Solicitar Cotización</span>
            <svg
              class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </a>

          <a
            href="/servicios"
            class="border-2 border-slate-600 text-white px-10 py-4 rounded-full font-semibold hover:border-emerald-500 hover:bg-emerald-500/10 transition-all duration-300 flex items-center justify-center space-x-2 group"
          >
            <span>Ver Servicios</span>
            <svg
              class="w-5 h-5 group-hover:rotate-45 transition-transform duration-300"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="mt-12 pt-8 border-t border-slate-700/50">
          <div class="flex flex-wrap justify-center items-center gap-8">
            <div class="flex items-center space-x-2 text-slate-300">
              <svg
                class="w-6 h-6 text-emerald-400"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="font-medium">Respuesta en 24 hrs</span>
            </div>
            <div class="flex items-center space-x-2 text-slate-300">
              <svg
                class="w-6 h-6 text-emerald-400"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="font-medium">Cotización sin costo</span>
            </div>
            <div class="flex items-center space-x-2 text-slate-300">
              <svg
                class="w-6 h-6 text-emerald-400"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"
                ></path>
              </svg>
              <span class="font-medium">Equipo experto</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
