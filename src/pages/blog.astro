---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../utils/format";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const featuredPost = allPosts.find((p) => p.data.featured) || allPosts[0];
const regularPosts = allPosts.filter((p) => p.id !== featuredPost.id);

const categories = ["Todos", ...new Set(allPosts.map((p) => p.data.category))];
---

<BaseLayout
  title="Blog Devint | Estrategia, desarrollo y tecnología"
  description="Artículos sobre transformación digital, costos de desarrollo, cómo digitalizar tu empresa y tecnología para PYME en Chile."
>
  <Header />

  <main class="pt-24">
    <!-- Hero del Blog -->
    <section class="pb-8 pt-4">
      <div class="container mx-auto px-6 text-center">
        <span
          class="mb-4 inline-block rounded-full border border-emerald-400/30 bg-emerald-400/10 px-4 py-1.5 text-sm font-medium text-emerald-300"
        >
          Blog & Recursos
        </span>
        <h1 class="mb-4 text-4xl font-bold text-white md:text-5xl">
          Ideas para llevar tu tecnología<br class="hidden md:block" /> al siguiente
          nivel
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-slate-400">
          Guías prácticas, precios reales y estrategias de digitalización para
          empresas chilenas. Sin tecnicismos innecesarios.
        </p>
      </div>
    </section>

    <!-- Artículo Destacado -->
    {
      featuredPost && (
        <section class="py-8">
          <div class="container mx-auto px-6">
            <p class="mb-4 text-xs uppercase tracking-widest text-emerald-400">
              Artículo destacado
            </p>
            <a
              href={`/blog/${featuredPost.id.replace(/\.md$/, "")}`}
              class="group block overflow-hidden rounded-3xl border border-emerald-500/30 bg-gradient-to-br from-slate-800/80 to-slate-900/80 transition-all duration-300 hover:border-emerald-400/50 hover:shadow-lg hover:shadow-emerald-500/10 md:flex"
            >
              <div class="md:w-2/5 lg:w-1/2">
                <img
                  src={featuredPost.data.image}
                  alt={featuredPost.data.title}
                  class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105 md:h-full"
                  loading="eager"
                />
              </div>
              <div class="flex flex-col justify-center space-y-4 p-8 md:w-3/5 lg:w-1/2">
                <div class="flex items-center gap-3">
                  <span class="rounded-full bg-emerald-400/15 px-3 py-1 text-xs font-semibold text-emerald-300">
                    {featuredPost.data.category}
                  </span>
                  <span class="text-xs text-slate-400">
                    {formatDate(featuredPost.data.publishDate)}
                  </span>
                </div>
                <h2 class="text-2xl font-bold text-white transition-colors group-hover:text-emerald-200 md:text-3xl">
                  {featuredPost.data.title}
                </h2>
                <p class="text-base leading-relaxed text-slate-300">
                  {featuredPost.data.excerpt}
                </p>
                <div class="flex items-center justify-between">
                  <span class="text-sm text-slate-400">
                    Por {featuredPost.data.author}
                    {featuredPost.data.readingTime &&
                      ` · ${featuredPost.data.readingTime} min de lectura`}
                  </span>
                  <span class="flex items-center gap-2 text-sm font-semibold text-emerald-300">
                    Leer artículo
                    <svg
                      class="h-4 w-4 transition-transform group-hover:translate-x-1"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 12h14m-7-7 7 7-7 7"
                      />
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          </div>
        </section>
      )
    }

    <!-- Filtros por Categoría -->
    <section class="py-6">
      <div class="container mx-auto px-6">
        <div class="flex flex-wrap gap-2" id="category-filters">
          {
            categories.map((cat) => (
              <button
                class="category-btn rounded-full border px-4 py-2 text-sm font-medium transition-all duration-200"
                data-category={cat}
                data-active={cat === "Todos" ? "true" : "false"}
              >
                {cat}
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Grid de Artículos -->
    <section class="pb-20 pt-4">
      <div class="container mx-auto px-6">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="posts-grid">
          {
            regularPosts.map(({ id, data }) => (
              <article
                class="post-card group overflow-hidden rounded-2xl border border-slate-700/60 bg-slate-900/50 transition-all duration-300 hover:-translate-y-1 hover:border-emerald-400/30 hover:shadow-md hover:shadow-emerald-500/5"
                data-category={data.category}
              >
                <div class="overflow-hidden">
                  <img
                    src={data.image}
                    alt={data.title}
                    class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="flex flex-col gap-3 p-5">
                  <div class="flex items-center justify-between">
                    <span class="rounded-full bg-slate-800 px-3 py-1 text-xs font-medium text-emerald-300">
                      {data.category}
                    </span>
                    {data.readingTime && (
                      <span class="text-xs text-slate-500">
                        {data.readingTime} min
                      </span>
                    )}
                  </div>
                  <h2 class="text-lg font-semibold leading-snug text-white transition-colors group-hover:text-emerald-200">
                    {data.title}
                  </h2>
                  <p class="line-clamp-3 text-sm leading-relaxed text-slate-400">
                    {data.excerpt}
                  </p>
                  <div class="mt-auto flex items-center justify-between border-t border-slate-700/50 pt-3">
                    <span class="text-xs text-slate-500">
                      {formatDate(data.publishDate)}
                    </span>
                    <a
                      href={`/blog/${id.replace(/\.md$/, "")}`}
                      class="flex items-center gap-1.5 text-xs font-semibold text-emerald-300 transition-colors hover:text-emerald-200"
                    >
                      Leer
                      <svg
                        class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 12h14m-7-7 7 7-7 7"
                        />
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        <!-- Estado vacío al filtrar -->
        <div id="no-posts" class="hidden py-16 text-center">
          <p class="text-slate-400">
            No hay artículos en esta categoría todavía.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA suscripción / contacto -->
    <section class="py-16 bg-gradient-to-br from-slate-900 to-slate-800">
      <div class="container mx-auto px-6 text-center">
        <h2 class="mb-4 text-2xl font-bold text-white md:text-3xl">
          ¿Tienes un proyecto en mente?
        </h2>
        <p class="mb-8 text-slate-400 max-w-xl mx-auto">
          Cuéntanos sobre tu empresa y te ayudamos a definir el siguiente paso
          en tu transformación digital.
        </p>
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 rounded-full bg-emerald-500 px-8 py-3.5 font-semibold text-slate-900 transition-all hover:bg-emerald-400 hover:shadow-lg hover:shadow-emerald-500/30"
        >
          Hablar con un especialista
          <svg
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 12h14m-7-7 7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .category-btn[data-active="true"] {
    @apply border-emerald-400 bg-emerald-400/15 text-emerald-300;
  }
  .category-btn[data-active="false"] {
    @apply border-slate-600 bg-transparent text-slate-400 hover:border-slate-400 hover:text-slate-200;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".category-btn");
  const cards = document.querySelectorAll<HTMLElement>(".post-card");
  const noPostsEl = document.getElementById("no-posts");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const selected = btn.dataset.category ?? "Todos";

      // Update active state
      buttons.forEach((b) => (b.dataset.active = "false"));
      btn.dataset.active = "true";

      // Filter cards
      let visible = 0;
      cards.forEach((card) => {
        const match =
          selected === "Todos" || card.dataset.category === selected;
        card.style.display = match ? "" : "none";
        if (match) visible++;
      });

      if (noPostsEl) {
        noPostsEl.classList.toggle("hidden", visible > 0);
      }
    });
  });
</script>
